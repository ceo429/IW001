# =============================================================================
# IOTWORKS DESK — Environment Variables (example)
#
# Copy to `.env` and fill in. NEVER commit `.env`.
# =============================================================================

# ─── Runtime ────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── Web (apps/web) ─────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:3000/v1
VITE_APP_NAME="IOTWORKS DESK"

# ─── API (apps/api) ─────────────────────────────────────────────────────
API_PORT=3000
API_CORS_ORIGIN=http://localhost:5173

# PostgreSQL (Prisma)
DATABASE_URL="postgresql://iw001:iw001_dev_pw@localhost:5432/iw001?schema=public"

# Redis (sessions, rate limit, cache)
REDIS_URL="redis://localhost:6379"

# ─── JWT secrets (generate with: openssl rand -base64 48) ───────────────
JWT_ACCESS_SECRET="replace-me-with-random-48-bytes-base64"
JWT_REFRESH_SECRET="replace-me-with-different-random-48-bytes-base64"
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ─── Initial admin seed (first boot only) ───────────────────────────────
SEED_ADMIN_EMAIL=admin@iotworks.kr
SEED_ADMIN_NAME="최고관리자"
SEED_ADMIN_PASSWORD="ChangeMeOnFirstLogin!"

# ─── Rate limiting ──────────────────────────────────────────────────────
RATE_LIMIT_LOGIN_PER_15M=5
RATE_LIMIT_API_PER_MIN=600

# ─── Observability ──────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_PRETTY=true
