{
  "name": "@iw001/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "IOTWORKS DESK Web — React + Vite + TS + Tailwind",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
